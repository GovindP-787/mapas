# MAPAS Backend Configuration
# Copy this file to .env and update with your values

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=mapas_db
MONGODB_ANNOUNCEMENTS_COLLECTION=announcements

# API Configuration
APP_NAME=MAPAS Food Delivery Backend
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Face Verification Settings
FACE_DETECTION_THRESHOLD=0.5
FACE_VERIFICATION_THRESHOLD=0.45
FACE_DETECTION_SIZE=640,640

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# InsightFace Model
INSIGHTFACE_MODEL=buffalo_l

# TTS Configuration
# Options: pyttsx3 (offline), gtts (requires internet)
TTS_ENGINE=pyttsx3
